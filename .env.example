# Chiave football-data.org (gratuita) — risultati, classifiche, calendari, marcatori
# Ottienila da https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=LA_TUA_CHIAVE_QUI

# Chiave API-Football (gratuita, https://dashboard.api-football.com) — usata SOLO
# dall'updater per Europa League e Nations League (non coperte da football-data)
API_FOOTBALL_KEY=LA_TUA_CHIAVE_QUI

# Stagione d'inizio di riferimento (2026 = 2026-27). Fallback automatico
# all'ultima stagione con partite giocate se quella preferita non è iniziata.
SEASON=2026
